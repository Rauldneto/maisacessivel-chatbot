# Variáveis de ambiente do chatbot Ace - Mais Acessível
# Copie este arquivo para .env e preencha com seus valores reais

# Chave da API da Anthropic (obtenha em https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXX

# Token de autenticação do Bling MCP (obtenha em Configurações > API no Bling)
BLING_MCP_TOKEN=SEU_TOKEN_BLING_AQUI

# Porta do servidor (o Render define automaticamente, não precisa alterar)
PORT=3000
